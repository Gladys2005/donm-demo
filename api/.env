# Configuration de la base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=donm_db
DB_USER=postgres
DB_PASSWORD=2005

# Configuration du serveur
PORT=3000
NODE_ENV=development

# Clé secrète JWT
JWT_SECRET=donm_jwt_secret_key_2024

# Configuration CORS
CORS_ORIGIN=*

# Configuration Mobile Money APIs
# Orange Money
ORANGE_API_URL=https://api.orange.com/orange-money
ORANGE_CLIENT_ID=votre_client_id_orange
ORANGE_CLIENT_SECRET=votre_client_secret_orange
ORANGE_API_KEY=votre_api_key_orange
ORANGE_MERCHANT_KEY=votre_merchant_key_orange

# MTN Mobile Money
MTN_API_URL=https://api.mtn.com/momo
MTN_CLIENT_ID=votre_client_id_mtn
MTN_CLIENT_SECRET=votre_client_secret_mtn
MTN_API_KEY=votre_api_key_mtn

# MoMo
MOMO_API_URL=https://api.momo.africa
MOMO_API_KEY=votre_api_key_momo
MOMO_MERCHANT_ID=votre_merchant_id_momo

# URLs de callback pour les paiements
BASE_URL=http://localhost:3000

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
